{
  "name": "@hirokisakabe/pom-md",
  "version": "2.0.0",
  "description": "Markdown wrapper for pom — write slides in Markdown with pomxml code fences.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "homepage": "https://github.com/hirokisakabe/pom#readme",
  "bugs": {
    "url": "https://github.com/hirokisakabe/pom/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hirokisakabe/pom.git",
    "directory": "packages/pom-md"
  },
  "license": "MIT",
  "keywords": [
    "powerpoint",
    "pptx",
    "presentation",
    "slides",
    "markdown",
    "pom"
  ],
  "author": "Hiroki Sakabe",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@vitest/coverage-v8": "^4.1.1",
    "typescript-eslint": "^8.47.0"
  }
}
