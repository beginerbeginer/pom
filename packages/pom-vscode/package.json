{
  "name": "pom-vscode",
  "private": true,
  "displayName": "pom",
  "description": "Live preview for pom-md / pom XML presentations",
  "version": "0.3.1",
  "publisher": "hirokisakabe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hirokisakabe/pom.git",
    "directory": "packages/pom-vscode"
  },
  "engines": {
    "node": ">=20",
    "vscode": "^1.85.0"
  },
  "icon": "icon.png",
  "categories": [
    "Visualization"
  ],
  "keywords": [
    "presentation",
    "powerpoint",
    "pptx",
    "markdown",
    "preview"
  ],
  "galleryBanner": {
    "color": "#7C3AED",
    "theme": "dark"
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pom.openPreview",
        "title": "pom: Open Preview",
        "icon": {
          "dark": "icons/preview-dark.svg",
          "light": "icons/preview-light.svg"
        }
      },
      {
        "command": "pom.exportPptx",
        "title": "pom: Export PPTX"
      }
    ],
    "configuration": {
      "title": "pom",
      "properties": {
        "pom.preview.defaultZoom": {
          "type": "string",
          "enum": [
            "fit",
            "50",
            "75",
            "100",
            "150"
          ],
          "enumItemLabels": [
            "Fit to Width",
            "50%",
            "75%",
            "100%",
            "150%"
          ],
          "default": "fit",
          "description": "Default zoom level for the pom preview panel."
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "when": "resourceFilename =~ /\\.pom\\.(md|xml)$/",
          "command": "pom.openPreview",
          "group": "navigation"
        },
        {
          "when": "resourceFilename =~ /\\.pom\\.(md|xml)$/",
          "command": "pom.exportPptx",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "lint": "eslint",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "node esbuild.mjs --test && vscode-test",
    "test:vsix": "node esbuild.mjs --test && vsce package --no-dependencies && node run-vsix-test.mjs",
    "test:vsix:clean": "rm -f *.vsix"
  },
  "devDependencies": {
    "@hirokisakabe/pom": "workspace:*",
    "@hirokisakabe/pom-md": "workspace:*",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25",
    "@types/vscode": "^1.85.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.28.0",
    "mocha": "^11.7.5",
    "pptx-glimpse": "^0.10.3",
    "sharp": "^0.34.5",
    "typescript-eslint": "^8.58.0"
  }
}
