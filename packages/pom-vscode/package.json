{
  "name": "pom-vscode",
  "displayName": "pom",
  "description": "Live preview for pom-md presentations",
  "version": "0.1.0",
  "publisher": "hirokisakabe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hirokisakabe/pom.git",
    "directory": "packages/pom-vscode"
  },
  "engines": {
    "node": ">=20",
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pom.openPreview",
        "title": "pom: Open Preview",
        "icon": "$(open-preview)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceFilename =~ /\\.pom\\.md$/",
          "command": "pom.openPreview",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "lint": "eslint",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@hirokisakabe/pom": "file:../../",
    "@hirokisakabe/pom-md": "file:../pom-md",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "jiti": "^2.6.1",
    "pptx-glimpse": "^0.5.0",
    "prettier": "3.6.2",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.47.0",
    "vitest": "^4.1.1"
  }
}
