{
  "name": "pom-vscode",
  "private": true,
  "displayName": "pom",
  "description": "Live preview for pom-md / pom XML presentations",
  "version": "0.1.3",
  "publisher": "hirokisakabe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hirokisakabe/pom.git",
    "directory": "packages/pom-vscode"
  },
  "engines": {
    "node": ">=20",
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pom.openPreview",
        "title": "pom: Open Preview",
        "icon": "$(open-preview)"
      },
      {
        "command": "pom.exportPptx",
        "title": "pom: Export PPTX",
        "icon": "$(desktop-download)"
      }
    ],
    "configuration": {
      "title": "pom",
      "properties": {
        "pom.preview.defaultZoom": {
          "type": "string",
          "enum": [
            "fit",
            "50",
            "75",
            "100",
            "150"
          ],
          "enumItemLabels": [
            "Fit to Width",
            "50%",
            "75%",
            "100%",
            "150%"
          ],
          "default": "fit",
          "description": "Default zoom level for the pom preview panel."
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "when": "resourceFilename =~ /\\.pom\\.(md|xml)$/",
          "command": "pom.openPreview",
          "group": "navigation"
        },
        {
          "when": "resourceFilename =~ /\\.pom\\.(md|xml)$/",
          "command": "pom.exportPptx",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "lint": "eslint",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "test": "vitest",
    "test:run": "vitest run",
    "test:integration": "node esbuild.mjs --test && vscode-test",
    "test:vsix": "node esbuild.mjs --test && vsce package --no-dependencies && node run-vsix-test.mjs",
    "test:vsix:clean": "rm -f *.vsix"
  },
  "devDependencies": {
    "@hirokisakabe/pom": "workspace:*",
    "@hirokisakabe/pom-md": "workspace:*",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22",
    "@types/vscode": "^1.85.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0",
    "mocha": "^11.7.5",
    "pptx-glimpse": "^0.10.1",
    "sharp": "^0.34.5",
    "typescript-eslint": "^8.47.0"
  }
}
