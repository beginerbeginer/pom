{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "project": ["src/**/*.ts", "*.mjs"],
  "ignoreBinaries": ["eslint", "prettier", "tsc", "vitest"],
  "ignoreDependencies": ["typescript-eslint", "vitest", "sharp"],
  "vitest": {
    "config": ["vitest.config.ts"]
  },
  "rules": {
    "exports": "warn"
  }
}
